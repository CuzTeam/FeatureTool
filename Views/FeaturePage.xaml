<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FeatureTool.Views.FeaturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:FeatureTool.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 搜索框 + 添加按钮 -->
        <Grid Grid.Row="0"
              Margin="16,8,16,12"
              ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="搜索特性（名称或 ID）"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged" />

            <Button x:Name="AddFeatureButton"
                    Grid.Column="1"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="AddFeature_Click"
                    ToolTipService.ToolTip="添加特性 ID">
                <FontIcon Glyph="&#xE710;"
                          FontSize="14" />
            </Button>
        </Grid>

        <!-- 特性列表 -->
        <ListView x:Name="FeatureList"
                  Grid.Row="1"
                  Padding="16,0,16,8"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,0,12,0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FeatureItem">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12,20,12">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Vertical"
                                        Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Id}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </Border>
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind StateLabel, Mode=OneWay}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Priority}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                      IsThreeState="True"
                                      IsChecked="{x:Bind IsChecked, Mode=OneWay}"
                                      IsEnabled="{x:Bind IsEditable, Mode=OneWay}"
                                      VerticalAlignment="Center"
                                      Click="FeatureCheckBox_Click" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xE721;"
                      FontSize="28"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="没有匹配的特性"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 状态提示条 -->
        <InfoBar x:Name="InfoBar"
                 Grid.Row="1"
                 Margin="16,0,16,8"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Stretch"
                 IsClosable="True"
                 IsOpen="False" />

        <!-- 添加特性对话框 -->
        <ContentDialog x:Name="AddFeatureDialog"
                       Title="添加特性"
                       PrimaryButtonText="添加"
                       SecondaryButtonText="取消"
                       DefaultButton="Primary"
                       PrimaryButtonClick="AddFeatureDialog_PrimaryClick">
            <StackPanel Spacing="12"
                        Width="320">
                <TextBox x:Name="NewFeatureIdBox"
                         Header="特性 ID"
                         PlaceholderText="例如 57156807"
                         TextChanged="NewFeatureIdBox_TextChanged" />
                <ComboBox x:Name="NewFeatureStateBox"
                          Header="状态"
                          SelectedIndex="0">
                    <x:String>启用</x:String>
                    <x:String>禁用</x:String>
                </ComboBox>
                <TextBox x:Name="NewFeatureNoteBox"
                         Header="注释（可选）"
                         PlaceholderText="例如：开始菜单新布局" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
