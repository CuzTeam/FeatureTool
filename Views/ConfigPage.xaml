<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FeatureTool.Views.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12" MaxWidth="720">
            <TextBlock Text="配置"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <TextBlock Text="特性列表"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,12,0,0" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12">
                <ToggleSwitch x:Name="ShowReadOnlyToggle"
                              Header="显示不可配置项"
                              OffContent="隐藏"
                              OnContent="显示"
                              Toggled="ShowReadOnlyToggle_Toggled"
                              ToolTipService.ToolTip="开启后列表会显示 ImageDefault/EKB/Security 等不可改的底层特性" />
            </Border>

            <TextBlock Text="关闭时仅显示可修改的特性（优先级为 Service/Dynamic/User/Test 等）。开启后会显示全部特性，包括不可改的 ImageDefault、ImageOverride、EKB、Security 等。"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</Page>
